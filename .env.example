# ---------------------------------------------------------------------------
# Copy this file to .env and fill in real values. Never commit the real .env.
# ---------------------------------------------------------------------------

# Google Gemini API key (https://aistudio.google.com/apikey).
# OPTIONAL: if left blank, the assistant automatically runs in "fallback mode"
# using a deterministic rule engine instead of calling the Gemini API. This
# keeps the app fully demoable with zero setup.
GEMINI_API_KEY=

# Gemini model id. gemini-2.5-flash is fast, cheap and generally available.
# Swap to gemini-flash-latest or gemini-3-flash-preview for newer capability.
GEMINI_MODEL=gemini-2.5-flash

# Port the Express server listens on.
PORT=3000

# Comma-separated list of origins allowed to call the API (CORS).
# Use "*" only for local demo purposes.
ALLOWED_ORIGINS=http://localhost:3000

# Max chat requests allowed per IP per minute (abuse / cost protection).
CHAT_RATE_LIMIT_PER_MINUTE=20

# Node environment: development | production | test
NODE_ENV=development
