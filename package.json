{
  "name": "worldcup-fan-assistant",
  "version": "1.0.0",
  "description": "Multilingual, accessibility-first GenAI assistant for FIFA World Cup 2026 fan navigation, crowd safety, transport and operational intelligence.",
  "keywords": [
    "genai",
    "gemini",
    "fifa-world-cup-2026",
    "accessibility",
    "smart-stadium",
    "multilingual"
  ],
  "license": "MIT",
  "author": "Sri",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SriRamkunamsetty/worldcup-fan-assistant.git"
  },
  "bugs": {
    "url": "https://github.com/SriRamkunamsetty/worldcup-fan-assistant/issues"
  },
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "jest --runInBand",
    "test:coverage": "jest --runInBand --coverage",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"public/**/*.{js,css,html}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"public/**/*.{js,css,html}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^7.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.6",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.15.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.14.0"
  }
}
